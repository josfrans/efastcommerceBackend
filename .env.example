# --- Database Configuration ---
# Default targets local SQL Server Express using Windows Authentication
CONNECTION_STRING="Server=localhost\SQLEXPRESS;Database=EFastCommerce;Trusted_Connection=True;TrustServerCertificate=True;"

# --- JWT Configuration ---
# Use a custom secret key (minimum 32 characters long)
JWT_KEY="super_secret_key_that_is_at_least_32_characters_long_for_security"
JWT_ISSUER="EFastCommerce"
JWT_AUDIENCE="EFastCommerceApp"
