# --- Database Configuration ---
# Default targets local SQL Server Express using Windows Authentication
CONNECTION_STRING="Server=localhost\SQLEXPRESS;Database=EFastCommerceDB;Trusted_Connection=True;TrustServerCertificate=True"

# --- JWT Configuration ---
# Use a custom secret key (minimum 32 characters long)
JWT_KEY="super_secret_key_that_is_at_least_32_characters_long_for_security"
JWT_ISSUER="EFastCommerce"
JWT_AUDIENCE="EFastCommerceApp"

# SMTP Configuration (For password recovery emails)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USERNAME="tu_correo@gmail.com"
SMTP_PASSWORD="tu_app_password"
SMTP_ENABLE_SSL="true"
